# Copy to .env and fill in your Atlas user/password.
# Add a database name in the path, e.g. ...mongodb.net/trade-journal?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/trade-journal?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=change-this-to-a-long-random-string

# Optional: trade screenshots (required if uploading images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
